# ─── secrets ──────────────────────────────────────────────────────────────────
# GitHub PAT with `models:read` scope. https://github.com/settings/personal-access-tokens
# Used as the bearer token for GitHub Models (OpenAI-compatible endpoint).
GITHUB_TOKEN=ghp_replace_me

# ─── GitHub Models ────────────────────────────────────────────────────────────
# Production endpoint (the older models.inference.ai.azure.com is deprecated and
# rejects fine-grained PATs).
GITHUB_MODELS_ENDPOINT=https://models.github.ai/inference
GITHUB_MODELS_CHAT_MODEL=openai/gpt-4o-mini
GITHUB_MODELS_EMBED_MODEL=openai/text-embedding-3-small

# ─── backend ──────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000

# ─── frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BACKEND_HTTP=http://localhost:8000
NEXT_PUBLIC_BACKEND_WS=ws://localhost:8000

# ─── infra (Docker Compose) ───────────────────────────────────────────────────
POSTGRES_USER=regression
POSTGRES_PASSWORD=regression
POSTGRES_DB=regression
POSTGRES_PORT=5433

QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# ─── RAG (Phase 1) ────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
RAG_TOP_K=5
RAG_MIN_SCORE=0.30

# ─── Atlassian / Jira (Phase 2 — required for scraper + drive mode) ───────────
# Get an API token at https://id.atlassian.com/manage-profile/security/api-tokens
# Same token works for both Jira REST and Confluence.
JIRA_BASE_URL=https://hyland.atlassian.net
ATLASSIAN_EMAIL=
ATLASSIAN_API_TOKEN=

# ─── Confluence (Phase 1, optional — leave blank to skip Confluence ingest) ───
CONFLUENCE_BASE_URL=
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=
# comma-separated space keys, e.g. SBPPA,QUAL,OB26
CONFLUENCE_SPACE_KEYS=

# ─── MRG (Phase 1, optional — leave blank to skip) ────────────────────────────
# Path to a folder of exported MRG entries (.md / .txt / .html)
MRG_DATA_DIR=

# ─── Phase 2+ (leave blank for now) ───────────────────────────────────────────
ATLASSIAN_CLOUD_ID=252cce86-035e-4b0e-abd2-3c002935632f
ATLASSIAN_OAUTH_CLIENT_ID=
ATLASSIAN_OAUTH_CLIENT_SECRET=
NEXTAUTH_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
